rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function userOrg() {
      return request.auth.token.orgId;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function sameOrg(resourceOrg) {
      return isSignedIn() && resourceOrg == userOrg();
    }

    match /shipments/{shipmentId} {
      allow read: if sameOrg(resource.data.orgId) || isAdmin();
      allow create: if isSignedIn() && sameOrg(request.resource.data.orgId);
      allow update, delete: if isAdmin() || sameOrg(resource.data.orgId);
    }

    match /alerts/{alertId} {
      allow read: if sameOrg(resource.data.orgId) || isAdmin();
      allow create, update: if isAdmin() || sameOrg(request.resource.data.orgId);
    }

    match /audit_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create, update, delete: if isAdmin();
    }
  }
}
